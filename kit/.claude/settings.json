{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.production)",
      "Read(.env.staging)",
      "Read(.env.development)",
      "Read(.env.test)",
      "Read(**/.env)",
      "Read(**/.env.production)",
      "Read(**/.env.staging)",
      "Read(**/.env.development)",
      "Read(**/.env.test)",
      "Read(**/secrets/**)",
      "Read(**/*secret*)",
      "Read(**/*credentials*)",
      "Read(**/*.token)",
      "Read(**/*token*.json)",
      "Read(**/*auth*token*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)"
    ],
    "ask": [
      "Read(.env.local)",
      "Read(**/.env.local)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/context-control-watchdog.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/context-control-watchdog.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/context-control-watchdog.py\""
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob|Edit|Write|MultiEdit|Agent|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/delegation-audit.py\""
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/plan-summary-enforcer.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/roadmap-task-status-sync.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/vitrine-sync-reminder.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/painel-sync-reminder.py\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/context-control-watchdog.py\""
          }
        ]
      }
    ]
  }
}
